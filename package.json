{
  "name": "tracepilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "tsx watch apps/api/src/index.ts",
    "build": "tsc -p tsconfig.json && vite build && tsc -p tsconfig.server.json",
    "build:web": "tsc -p tsconfig.json && vite build",
    "build:api": "tsc -p tsconfig.server.json",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node dist-server/apps/api/src/index.js",
    "db:migrate:deploy": "prisma migrate deploy",
    "lint": "eslint .",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.0.0",
    "@prisma/client": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lighthouse": "^13.4.0",
    "lucide-react": "^0.468.0",
    "playwright": "^1.49.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
